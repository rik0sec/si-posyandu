#---------------------------
# Operating Specific Junk Files
#---------------------------

# OS X
.DS_Store
.AppleDouble
.LSOverride

# OS X Thumbnails
._*

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini

# Windows shortcuts
*.lnk

# Linux
*~

#---------------------------
# Environment & sensitive files
#---------------------------
.env
.htaccess.bak

#---------------------------
# Dependencies
#---------------------------
/vendor/
/node_modules/

#---------------------------
# CodeIgniter specific
#---------------------------
/writable/cache/*
!/writable/cache/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html
/writable/debugbar/*

#---------------------------
# Raw database/MySQL files (jangan sampai ke-commit)
#---------------------------
*.frm
*.ibd
*.myd
*.myi
db.opt

#---------------------------
# IDE / Editor
#---------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace